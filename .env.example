# ============================
# VidCraft Environment Variables
# ============================
# Copy to .env and fill in real values
# WARNING: .env must NEVER be committed to Git

# --- Node Environment ---
NODE_ENV=development

# --- Database (PostgreSQL 16 + pgvector) ---
DATABASE_URL=postgresql://vidcraft:vidcraft@localhost:5432/vidcraft
DB_HOST=localhost
DB_PORT=5432
DB_USER=vidcraft
DB_PASSWORD=vidcraft
DB_NAME=vidcraft

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vidcraft-media

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- Volcano Engine (火山引擎) OpenAPI ---
VOLCANO_ACCESS_KEY=your-volcano-access-key
VOLCANO_SECRET_KEY=your-volcano-secret-key
VOLCANO_REGION=cn-north-1
DOUBAO_MODEL=doubao-seed-2.0-pro
DOUBAO_VISION_MODEL=doubao-vision-pro
SEEDANCE_MODEL=doubao-seedance-1.5-pro
TTS_VOICE_ID=zh_female_qingxin
VOLCANO_TTS_APP_ID=your-tts-app-id
VOLCANO_TTS_ACCESS_KEY=your-tts-access-key
VOLCANO_TTS_RESOURCE_ID=seed-tts-2.0
VOLCANO_DOUBAO_SEED_EP=your-doubao-seed-endpoint-id
VOLCANO_SEEDANCE_EP=your-seedance-endpoint-id
# 是否向 Seedance 传参考图（reference_image / r2v）。仅 Seedance 2.0 等支持 r2v 的端点可设 true；
# Seedance 1.5-pro 不支持 r2v，保持 false（参考图不上传，走纯文生/首尾帧）
VOLCANO_SEEDANCE_R2V_ENABLED=false

# --- Seedance Callback Security ---
SEEDANCE_CALLBACK_SECRET=change-me-hmac-signing-key
SEEDANCE_CALLBACK_BASE_URL=http://localhost:3000

# --- OpenTelemetry / Jaeger ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=vidcraft-api

# --- FastAPI Worker ---
FASTAPI_WORKER_URL=http://localhost:8000

# --- Demo / Tourist Account ---
DEMO_USER_EMAIL=demo@vidcraft.icu
DEMO_USER_PASSWORD=demo1234

# --- Resend (Email Service) ---
# Sign up at https://resend.com → API Keys
RESEND_API_KEY=re_placeholder
RESEND_FROM=VidCraft <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
