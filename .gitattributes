# Shell scripts must use LF for Linux containers
*.sh text eol=lf

# Docker files must use LF
Dockerfile* text eol=lf
.dockerignore text eol=lf
docker-compose*.yml text eol=lf

# Nginx config
*.conf text eol=lf

# Env files — CRLF would add \r to values
.env.production text eol=lf
.env.development text eol=lf
