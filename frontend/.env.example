# ============================
# Frontend Environment Variables
# ============================
# Copy to .env.local for personal overrides (gitignored)

# 后端 API base URL
# 留空时走 Vite proxy（/api → http://localhost:3000，见 vite.config.ts）
VITE_API_BASE_URL=

# 是否启用 MSW Mock
# 开发期默认开启，后端接口好了改成 false 用真接口
VITE_USE_MOCK=true

# WebSocket 服务地址
VITE_WS_URL=
